# Bytecode files generated by Python
*.pyc
__pycache__/

# macOS system file (safe to ignore)
.DS_Store

# Virtual environment (prevents committing unnecessary dependencies)
.venv/

# Backup directory (assuming you store temporary files here)
backup/

# ChromaDB directory (assuming it contains stored vector data)
chroma/

# Environment variables file (contains secrets like API keys)
.env

# Logs and temp files
*.log
*.out
*.err

# Jupyter Notebook checkpoints (if using Jupyter)
.ipynb_checkpoints/

# VSCode settings (if using VSCode)
.vscode/

# JetBrains IDE settings (if using PyCharm)
.idea/

# Any other temporary or compiled files
*.bak
*.swp